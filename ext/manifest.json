{
  "manifest_version": 3,
  "name": "BC Bid Scraper",
  "version": "1.1.0",
  "description": "Scrape contract award data from BC Bid and export as CSV or JSON",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.bcbid.gov.bc.ca/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bcbid.gov.bc.ca/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
