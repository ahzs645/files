# Public Vite client URL for the Convex websocket/http endpoint.
VITE_CONVEX_URL=http://127.0.0.1:3210

# Convex self-hosted CLI settings for `npx convex ...`.
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-me

# Convex function environment variables. Set these with `npx convex env set`.
SCRAPER_INTERNAL_BASE_URL=http://scraper:3001
SCRAPER_INTERNAL_TOKEN=replace-me
INGEST_SHARED_SECRET=replace-me

# Optional local scraper launch overrides.
SCRAPER_HEADLESS=true
SCRAPER_BROWSER_CHANNEL=
SCRAPER_BROWSER_ARGS=
